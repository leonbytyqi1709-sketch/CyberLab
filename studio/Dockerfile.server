# Gemeinsames Image für api-gateway UND simulation-engine.
# Der Befehl (server/index.ts bzw. server/sim.ts) wird in docker-compose gesetzt.
FROM node:20-alpine
WORKDIR /app
COPY package.json package-lock.json ./
RUN npm ci
COPY server ./server
COPY tsconfig.json ./
EXPOSE 3001
CMD ["npx", "tsx", "server/index.ts"]
